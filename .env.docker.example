# Per-worktree Docker config. Copy to .env.docker and edit per worktree:
#   cp .env.docker.example .env.docker
#
# .env.docker is gitignored; this .example is the source of truth for which
# vars exist. All required values must be set — Compose's ${VAR:?...} syntax
# fails loud on missing values, so a typo here never silently collides two
# worktrees on the same DB name or port.

# REQUIRED — host port for the web service (must be unique per worktree)
WEB_PORT=3000

# REQUIRED — host port for the ORM Studio service (must be unique per worktree)
STUDIO_PORT=5555

# REQUIRED — worktree-specific database name inside the shared Postgres instance
WORKTREE_DB=db_query_detective_dev_main

# REQUIRED — unique Compose project name per worktree (namespaces containers,
# volumes, and Auth.js cookies)
COMPOSE_PROJECT_NAME=db_query_detective-main

# OPTIONAL — opt in to additional services. Comma-separated, no spaces.
#   studio  — brings up Prisma/Drizzle Studio in the app tier
#   ngrok   — brings up the ngrok tunnel in the infra tier
# COMPOSE_PROFILES=studio,ngrok

# REQUIRED only if COMPOSE_PROFILES includes ngrok — your ngrok auth token
# NGROK_AUTHTOKEN=

# OPTIONAL — Vercel AI Gateway API key for the LLM "Ask the detective"
# recommendations (RFC 0001). Only needed to exercise that feature in LOCAL
# Docker; when set here it's forwarded to the web container (see
# docker-compose.app.yml). On Vercel (preview/production) leave it UNSET — the
# gateway authenticates via automatic OIDC, so no key is required there.
# VERCEL_AI_GATEWAY_API_KEY=
